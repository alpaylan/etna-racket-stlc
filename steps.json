{
  "setup_steps": [],
  "build_steps": [
    {
      "Command": {
        "command": "raco",
        "args": [
          "exe",
          "main.rkt"
        ]
      }
    },
    {
      "Command": {
        "command": "raco",
        "args": [
          "exe",
          "main-sampler.rkt"
        ]
      }
    }
  ],
  "capabilities": {
    "solve": [
      {
        "Command": {
          "command": "${workload_path}/main",
          "args": [
            "$property",
            "${strategy}"
          ],
          "params": [
            "workload_path",
            "property",
            "strategy"
          ]
        }
      }
    ],
    "sample": [
      {
        "Command": {
          "command": "${workload_path}/main-sampler",
          "args": [
            "$property",
            "$tests"
          ],
          "params": [
            "workload_path",
            "property",
            "strategy"
          ]
        }
      }
    ]
  }
}
